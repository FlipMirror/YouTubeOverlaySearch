{
  "manifest_version": 3,

  "name": "YouTube Overlay Search",

  "version": "1.0",
  "icons": {
        "16":"icons/16.png",
        "32":"icons/32.png",
        "48":"icons/48.png",
        "128":"icons/128.png"
    },
  "description": "Расширение для автоматического поиска видео YouTube по запросу из поисковой ситемы и запуска в отдельном Overlay плеере поверх существующей страницы",

  "permissions": [
    "windows",
    "tabs",
    "scripting",
    "activeTab",
    "storage",
    "webNavigation"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.google.com/*",
    "https://yandex.*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],

      "js": [
        "content.js"
      ],

      "css": [
        "overlay.css"
      ],

      "run_at": "document_idle"
    }
  ]
}